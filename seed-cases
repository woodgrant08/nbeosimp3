async function seed() {
  console.log("Seeding cases...");

  const existing = await db.select().from(casesTable);
  if (existing.length > 0) {
    console.log(`Database already has ${existing.length} cases. Skipping seed.`);
    return;
  }

  for (const c of cases) {
    await db.insert(casesTable).values({
      title: c.title,
      topic: c.topic,
      difficulty: c.difficulty,
      chiefComplaint: c.chiefComplaint,
      patientDemographics: c.patientDemographics,
      reviewOfSystems: c.reviewOfSystems,
      currentMedications: c.currentMedications,
      examFindings: c.examFindings,
      availableAncillaryTests: c.availableAncillaryTests,
      ancillaryTestResults: c.ancillaryTestResults,
      keyPoints: c.keyPoints,
      modelAssessment: c.modelAssessment,
      modelPlan: c.modelPlan,
      patientPersonality: c.patientPersonality,
    });
    console.log(`  Inserted: ${c.title}`);
  }

  console.log("Seeding complete!");
}

seed().catch(console.error).finally(() => process.exit(0));
